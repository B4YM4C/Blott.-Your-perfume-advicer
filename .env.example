# ============================================
# Blot. — Environment variables
# Copy to .env.local for local dev. On Vercel, set these in Project Settings.
# ============================================

# APP_MODE:  'local'      → use in-memory mockDb (loads /data/*.json)
#            'production' → use SQL database (Neon Postgres)
APP_MODE=local

# ----- DB (required when APP_MODE=production) ----------------------------
# One of:
#   1. DATABASE_URL (preferred — Neon, Vercel Postgres, Supabase)
#   2. POSTGRES_URL (Vercel Postgres convention; auto-injected by Vercel)
#   3. Split DB_HOST/DB_USER/... vars below
#
# Driver auto-detected from URL prefix; override with DB_DRIVER=postgres|mysql.
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
# DB_DRIVER=postgres

# Split-config fallback (only used if DATABASE_URL is empty)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=blott
# DB_PASSWORD=change_me
# DB_NAME=blott
# DB_SSL=true   # 'true' to require SSL; auto-on for *.neon.tech / *.supabase.co

# ----- Admin auth (HTTP basic in front of /admin and /api/admin) ---------
# In production, ADMIN_PASS is REQUIRED. If unset, /admin returns 503.
# In local dev, leaving ADMIN_PASS unset disables the prompt.
ADMIN_USER=admin
ADMIN_PASS=change_me_admin

# ----- File uploads (admin perfume images) -------------------------------
# When BLOTT_READ_WRITE_TOKEN is set, /api/admin/upload writes to Vercel Blob.
# Otherwise it falls back to local disk (works in dev only — Vercel's
# serverless filesystem is read-only).
# Set this manually in Vercel → Project Settings → Environment Variables,
# using the token from your (Public) Blob store.
# BLOTT_READ_WRITE_TOKEN=

# ----- Email (stubbed in beta; hook your provider here) ------------------
EMAIL_PROVIDER=stub      # 'stub' = log only | 'smtp' | 'sendgrid' | 'resend'
EMAIL_FROM=hello@blott.app

# ----- Tracking / PDPA ---------------------------------------------------
TRACKING_ENABLED=true
COOKIE_NAME=blott_session
COOKIE_MAX_AGE=2592000   # 30 days
